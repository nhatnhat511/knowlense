{
  "manifest_version": 3,
  "name": "Knowlense",
  "version": "1.0.0",
  "description": "Chrome extension that summarizes selected text with Wikipedia.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://en.wikipedia.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "https://knowlense.com/*",
      "https://www.knowlense.com/*"
    ]
  },
  "action": {
    "default_title": "Knowlense",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "apiService.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
