{
  "manifest_version": 3,
  "name": "Knowlense",
  "description": "SEO Health extension for TPT sellers with website-managed authentication.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://*.workers.dev/*",
    "https://api.knowlense.com/*",
    "https://www.teacherspayteachers.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.teacherspayteachers.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Knowlense",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
