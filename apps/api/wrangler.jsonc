{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "knowlense-api",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-26",
	// Replace these placeholders with your real D1 database id and name.
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "knowlense-db",
			"database_id": "f41180d0-210c-4552-930a-85c60ed605d4",
			"remote": true
		}
	],
	"triggers": {
		"crons": ["17 * * * *"]
	},
	"observability": {
		"enabled": true
	}
}
